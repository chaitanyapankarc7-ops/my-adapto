<?xml version="1.0" encoding="utf-8"?>
<!--
    HomeActivity layout — the "house". This activity no longer draws the
    dock, the app grid, or the widgets directly; those all moved into
    their own fragment layouts (fragment_home.xml, fragment_app.xml,
    fragment_widgets.xml — the "rooms"). All this layout does is:
      - dim the wallpaper so text/icons stay readable on any background
      - host the ViewPager2, which is where the 3 pages actually render
      - host a TabLayout so "Home / Apps / Widgets" can be tapped
        directly instead of only reachable by swiping
      - host the FAB, since "open accessibility settings" is common to
        every page rather than owned by any one of them
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Dimming overlay to make icons/text readable on any wallpaper -->
    <View
        android:id="@+id/view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tab_layout" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#CC1A1A2E"
        app:tabTextColor="#AAAAAA"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabIndicatorColor="#2563EB"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- FAB → Accessibility Settings. Floats above the pager, docked
         just above the tab bar so it never blocks a tab tap. -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:contentDescription="Accessibility Settings"
        app:srcCompat="@android:drawable/ic_menu_manage"
        app:tint="#FFFFFF"
        app:backgroundTint="#2563EB"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tab_layout" />

</androidx.constraintlayout.widget.ConstraintLayout>